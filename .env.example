# =============================================
# Stronger App — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env — ele já está no .gitignore.

# ---------------------------------------------------
# BANCO DE DADOS (configure no painel do Vercel também)
# ---------------------------------------------------

# Opção 1: String de conexão completa (Neon, Supabase, Railway, Render...)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require

# Opção 2: Credenciais individuais (para PostgreSQL local ou outro provedor)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=app_treino
# DB_USER=postgres
# DB_PASSWORD=sua_senha_aqui

# ---------------------------------------------------
# SETUP (proteção do endpoint de migração)
# ---------------------------------------------------
# Defina uma senha secreta para proteger o endpoint POST /api/setup
SETUP_SECRET=troque-por-uma-senha-segura
